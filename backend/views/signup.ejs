<%- include('partials/header', { 
    pageTitle: 'Signup', 
    active: '', 
    pageStyles: ['/css/style-login.css']  // using same style as login
}) %>

<div class="login-container">
  <div class="login-overlay"></div>

  <div class="login-content">

    <!-- LEFT SIDE TEXT -->
    <div class="login-text">
      <h1 class="login-title">
        Join the <span class="highlight">ThriftSaas</span> Community
      </h1>
      <p style="font-size:1.1rem; margin-top:10px;">
        Create your account to start buying, selling, and exploring curated thrift fashion.
      </p>
    </div>

    <!-- SIGNUP FORM -->
    <div class="login-form-container">

      <div class="form-header">
        <div class="logo">
          
        </div>
        <h2 class="form-title">Create Account</h2>
      </div>

      <form action="/auth/signup" method="POST">

        <div class="form-group">
          <label class="form-label">Full Name</label>
          <input 
            type="text" 
            name="name" 
            class="form-input" 
            placeholder="Enter your full name" 
            required
          >
        </div>

        <div class="form-group">
          <label class="form-label">Email</label>
          <input 
            type="email" 
            name="email" 
            class="form-input" 
            placeholder="Enter your email" 
            required
          >
        </div>

        <div class="form-group">
          <label class="form-label">Password</label>
          <input 
            type="password" 
            name="password" 
            class="form-input" 
            placeholder="Create a strong password" 
            required
          >
        </div>

        <button type="submit" class="login-btn">Sign Up</button>
      </form>

      <div class="signup-section">
        <p class="signup-text">Already have an account?</p>
        <a href="/login">
          <button class="signup-btn">Login</button>
        </a>
      </div>

    </div>
  </div>
</div>

<%- include('partials/footer', { pageScripts: ['/scripts/search.js'] }) %>
